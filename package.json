{
  "name": "re-prompt",
  "version": "0.1.0",
  "description": "Turn messy Codex sessions into better next prompts.",
  "type": "module",
  "bin": {
    "re-prompt": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^13.0.0",
    "diff": "^7.0.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "p-limit": "^6.2.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
